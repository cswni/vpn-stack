# VPN Stack Environment Variables
# Copy this file to .env and fill in your values

# VPS public IP address
WG_HOST=212.56.34.240

# WireGuard web UI password hash (bcrypt, with $ escaped as $$ for docker compose)
WG_PASSWORD_HASH=CHANGE_THIS_BCRYPT_HASH

# Pi-hole web UI password
PIHOLE_PASSWORD=CHANGE_THIS_PASSWORD

# Timezone
TZ=America/Managua
