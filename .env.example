# VPN Stack Environment Variables
# Copy this file to .env and fill in your values

# VPS public IP address
WG_HOST=212.56.34.240

# WireGuard web UI password hash (bcrypt, with $ escaped as $$ for docker compose)
WG_PASSWORD_HASH=CHANGE_THIS_BCRYPT_HASH

# Pi-hole web UI password
PIHOLE_PASSWORD=CHANGE_THIS_PASSWORD

# Timezone
TZ=America/Managua

# Optional Traefik deployment settings
VPN_DOMAIN=vpn.workingpos.com
DNS_DOMAIN=dns.workingpos.com
TRAEFIK_DOCKER_NETWORK=traefik-net
TRAEFIK_CONSTRAINT_LABEL=traefik-net
TRAEFIK_ENTRYPOINT=https
TRAEFIK_CERTRESOLVER=le
